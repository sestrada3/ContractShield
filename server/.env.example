# ContractShield Backend — Environment Variables
# Copy this file to server/.env for local development
# Set these in your Vercel project dashboard for production

ANTHROPIC_API_KEY=sk-ant-...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — get these from Stripe Dashboard → Products
# These must be PRICE IDs (price_xxx), NOT product IDs (prod_xxx)
STRIPE_PRICE_MONTHLY=price_1TY8noPwwT0D6amwKPNvzhTO
STRIPE_PRICE_YEARLY=price_1TY8npPwwT0D6amwuwTPZRm4
STRIPE_PRICE_CREDIT_1=price_REPLACE_WITH_SINGLE_ANALYSIS_PRICE_ID
STRIPE_PRICE_CREDIT_10=price_REPLACE_WITH_10_PACK_PRICE_ID

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
