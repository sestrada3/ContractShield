# ─────────────────────────────────────────────────
# ContractShield Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ─────────────────────────────────────────────────

# Your backend API URL (see server/ folder)
EXPO_PUBLIC_API_URL=https://your-backend.vercel.app

# Supabase (auth + database)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Stripe (payments)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your-key-here

# ─────────────────────────────────────────────────
# IMPORTANT: The Anthropic API key lives ONLY on
# your backend server — never in the mobile app.
# See server/.env for backend secrets.
# ─────────────────────────────────────────────────
